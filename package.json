{
  "name": "redline",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first review workspace for uncommitted Git changes.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "concurrently -k -n web,server -c cyan,magenta \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite",
    "dev:server": "PORT=4323 tsx watch server/index.ts",
    "start": "NODE_ENV=production node dist/server/server/index.js",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@fastify/static": "^9.3.0",
    "fastify": "^5.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
